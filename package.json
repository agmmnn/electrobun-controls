{
  "name": "electrobun-controls",
  "version": "0.1.0",
  "description": "Framework-agnostic native-looking window controls for Electrobun.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "sideEffects": [
    "./dist/style.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.js",
      "default": "./dist/dom.js"
    },
    "./electrobun": {
      "types": "./dist/electrobun.d.ts",
      "import": "./dist/electrobun.js",
      "default": "./dist/electrobun.js"
    },
    "./bun": {
      "types": "./dist/bun.d.ts",
      "import": "./dist/bun.js",
      "default": "./dist/bun.js"
    },
    "./style.css": {
      "types": "./dist/style.css.d.ts",
      "import": "./dist/style.css",
      "default": "./dist/style.css"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agmmnn/electrobun-controls.git"
  },
  "keywords": [
    "electrobun",
    "window-controls",
    "desktop",
    "titlebar",
    "bun"
  ],
  "peerDependencies": {
    "electrobun": ">=1.16.0"
  },
  "scripts": {
    "build": "tsdown && node scripts/postbuild.mjs && publint . && attw --pack . --profile esm-only",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^24.0.0",
    "electrobun": "^1.16.0",
    "jsdom": "^26.0.0",
    "publint": "^0.3.12",
    "tsdown": "^0.13.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.11"
}
